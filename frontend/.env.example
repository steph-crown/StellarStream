# =============================================================================
# StellarStream Frontend Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in the values
# These are PUBLIC variables that will be exposed to the browser

# =============================================================================
# Contract Configuration (Multi-Contract V1/V2 Support)
# =============================================================================

# V1 (Legacy) StellarStream Contract ID
# The original StellarStream contract deployed on Stellar
NEXT_PUBLIC_CONTRACT_ID=

# V2 (Nebula) Contract ID
# The new Nebula V2 contract with enhanced features
NEXT_PUBLIC_NEBULA_CONTRACT_ID=

# =============================================================================
# RPC Configuration
# =============================================================================

# Soroban RPC endpoint
# Default: Stellar SDF Public RPC
NEXT_PUBLIC_RPC_URL=https://soroban-rpc.stellar.org

# Alternative RPC endpoints for different networks:
# - Testnet: https://soroban-testnet.stellar.org
# - Futurenet: https://soroban-futurenet.stellar.org

# =============================================================================
# Network Configuration
# =============================================================================

# Network passphrase (for signature verification)
# Public: "Public Global Stellar Network ; September 2015"
# Testnet: "Test SDF Network ; September 2015"
NEXT_PUBLIC_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015

# =============================================================================
# Feature Flags
# =============================================================================

# Force emergency banner display (for testing)
# NEXT_PUBLIC_FORCE_EMERGENCY=true

# =============================================================================
# Usage Notes
# =============================================================================
# 
# 1. Both V1 and V2 contract IDs can be configured simultaneously
# 2. The frontend will automatically query balances for both contracts
# 3. Users can switch between V1 and V2 via the useContract('v1' | 'v2') hook
# 4. Combined balance is automatically calculated across both protocols
#
# Example usage in components:
#
# ```tsx
# import { useContract, useBalances, useWallet } from '@/lib/providers';
# import { CONTRACT_ID, NEBULA_CONTRACT_ID } from '@/lib/providers';
#
# function MyComponent() {
#   // Get specific contract
#   const v1Contract = useContract('v1');
#   const v2Contract = useContract('v2');
#
#   // Get user's balances across both protocols
#   const { v1, v2, combined } = useBalances();
#
#   // Access wallet info
#   const { address, balances } = useWallet();
# }
# ```
